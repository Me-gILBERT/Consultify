@model AppointmentListVM
@{
    ViewData["Title"] = "All Appointments";
}

<h1>All Appointments</h1>

<div class="mb-3">
    <form method="get" class="row g-2">
        <div class="col-auto">
            <select name="status" class="form-select" asp-items="ViewBag.Statuses">
                <option value="">All Statuses</option>
            </select>
        </div>
        <div class="col-auto">
            <button type="submit" class="btn btn-outline-primary">Filter</button>
        </div>
    </form>
</div>

@if (Model.Appointments.Count == 0)
{
    <div class="alert alert-info">No appointments found.</div>
}
else
{
    <table class="table table-striped">
        <thead>
            <tr>
                <th>Consultant</th>
                <th>Customer</th>
                <th>Date</th>
                <th>Time</th>
                <th>Status</th>
                <th>Actions</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var a in Model.Appointments)
            {
                <tr>
                    <td>@a.ConsultantProfile?.User?.FullName</td>
                    <td>@a.CustomerUser.FullName</td>
                    <td>@a.TimeSlot.StartTime.ToString("MMM dd, yyyy")</td>
                    <td>@a.TimeSlot.StartTime.ToString("HH:mm") - @a.TimeSlot.EndTime.ToString("HH:mm")</td>
                    <td>
                        <span class="badge @(a.Status == AppointmentStatus.Scheduled ? "bg-success" :
                                             a.Status == AppointmentStatus.Completed ? "bg-secondary" :
                                             a.Status == AppointmentStatus.Cancelled ? "bg-danger" : "bg-warning")">
                            @a.Status
                        </span>
                    </td>
                    <td>
                        @if (a.Status == AppointmentStatus.Scheduled)
                        {
                            <form asp-action="Cancel" asp-route-id="@a.Id" method="post" onsubmit="return confirm('Cancel this appointment?')">
                                @Html.AntiForgeryToken()
                                <div class="input-group input-group-sm">
                                    <input type="text" name="reason" class="form-control" placeholder="Reason..." />
                                    <button type="submit" class="btn btn-outline-danger">Cancel</button>
                                </div>
                            </form>
                        }
                    </td>
                </tr>
            }
        </tbody>
    </table>
}
