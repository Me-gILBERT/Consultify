@model UserListVM
@{
    ViewData["Title"] = "Manage Users";
}

<h1>Manage Users</h1>

<form method="get" class="row g-2 mb-3">
    <div class="col-md-4">
        <input type="text" name="search" class="form-control" placeholder="Search email or name..." value="@Model.SearchTerm" />
    </div>
    <div class="col-md-3">
        <select name="role" class="form-select">
            <option value="">All Roles</option>
            <option value="Admin" selected="@(Model.RoleFilter == "Admin")">Admin</option>
            <option value="Consultant" selected="@(Model.RoleFilter == "Consultant")">Consultant</option>
            <option value="Customer" selected="@(Model.RoleFilter == "Customer")">Customer</option>
        </select>
    </div>
    <div class="col-md-2">
        <button type="submit" class="btn btn-primary w-100">Filter</button>
    </div>
</form>

<table class="table table-striped">
    <thead>
        <tr>
            <th>Name</th>
            <th>Email</th>
            <th>Active</th>
            <th>Actions</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var user in Model.Users)
        {
            <tr>
                <td>@user.FullName</td>
                <td>@user.Email</td>
                <td>
                    @if (user.IsActive)
                    {
                        <span class="badge bg-success">Active</span>
                    }
                    else
                    {
                        <span class="badge bg-danger">Inactive</span>
                    }
                </td>
                <td>
                    <a asp-action="Details" asp-route-id="@user.Id" class="btn btn-sm btn-outline-info">Details</a>
                    <form asp-action="ToggleStatus" asp-route-id="@user.Id" method="post" class="d-inline">
                        @Html.AntiForgeryToken()
                        <button type="submit" class="btn btn-sm btn-outline-warning">
                            @(user.IsActive ? "Deactivate" : "Activate")
                        </button>
                    </form>
                </td>
            </tr>
        }
    </tbody>
</table>

<nav>
    <ul class="pagination">
        @for (int i = 1; i <= Model.TotalPages; i++)
        {
            <li class="page-item @(i == Model.Page ? "active" : "")">
                <a class="page-link" asp-action="Index" asp-route-page="@i" asp-route-role="@Model.RoleFilter" asp-route-search="@Model.SearchTerm">@i</a>
            </li>
        }
    </ul>
</nav>
