@model ConsultantDashboardVM
@{
    ViewData["Title"] = "Consultant Dashboard";
}

<h1>Dashboard</h1>

<div class="row mb-4">
    <div class="col-md-3">
        <div class="card text-bg-primary">
            <div class="card-body">
                <h5 class="card-title">Today</h5>
                <p class="card-text display-6">@Model.TodayCount</p>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card text-bg-success">
            <div class="card-body">
                <h5 class="card-title">This Week</h5>
                <p class="card-text display-6">@Model.WeeklyCount</p>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card text-bg-info">
            <div class="card-body">
                <h5 class="card-title">Total</h5>
                <p class="card-text display-6">@Model.TotalAppointments</p>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card text-bg-warning">
            <div class="card-body">
                <h5 class="card-title">Rating</h5>
                <p class="card-text display-6">@Model.AverageRating.ToString("0.0")</p>
            </div>
        </div>
    </div>
</div>

<div class="d-flex justify-content-between mb-3">
    <h2>Upcoming Appointments</h2>
    <a asp-action="Create" asp-controller="Availability" class="btn btn-primary">+ Create Time Slots</a>
</div>

@if (Model.UpcomingAppointments.Count == 0)
{
    <div class="alert alert-info">No upcoming appointments.</div>
}
else
{
    <table class="table table-striped">
        <thead>
            <tr>
                <th>Date</th>
                <th>Time</th>
                <th>Customer</th>
                <th>Status</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var appt in Model.UpcomingAppointments)
            {
                <tr>
                    <td>@appt.TimeSlot.StartTime.ToString("ddd, MMM dd yyyy")</td>
                    <td>@appt.TimeSlot.StartTime.ToString("HH:mm") - @appt.TimeSlot.EndTime.ToString("HH:mm")</td>
                    <td>@appt.CustomerUser.FullName</td>
                    <td><span class="badge bg-success">@appt.Status</span></td>
                </tr>
            }
        </tbody>
    </table>
}
